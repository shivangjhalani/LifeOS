# ──────────────────────────────────────────────────────────────
# LiteLLM Proxy — Environment Variables
# Copy this file to .env and fill in the values you need.
# ──────────────────────────────────────────────────────────────

# ── Proxy Auth ───────────────────────────────────────────────
# Master key acts as the admin API key for the proxy.
LITELLM_MASTER_KEY="sk-change-me-to-something-secret"

# Salt key encrypts/decrypts stored provider API keys.
# IMPORTANT: once you add models, do NOT change this value.
LITELLM_SALT_KEY="generate-a-random-string-here"

# ── Dashboard UI Login ───────────────────────────────────────
# Default: username "admin", password = LITELLM_MASTER_KEY. If you get
# "Invalid credentials", either use the master key as password, or set:
# UI_USERNAME="admin"
# UI_PASSWORD="your-chosen-password"

# ── Provider API Keys ────────────────────────────────────────
# Uncomment and fill in only the providers you use.

# OPENAI_API_KEY=""
# ANTHROPIC_API_KEY=""
# GROQ_API_KEY=""
# GEMINI_API_KEY=""

# ── Local Models (no key needed, just the base URL) ─────────
# OLLAMA_API_BASE="http://host.docker.internal:11434"
# VLLM_API_BASE="http://host.docker.internal:8000/v1"
# LM_STUDIO_API_BASE="http://host.docker.internal:1234/v1"
