# =============================================================================
# API Keys
# =============================================================================
# Groq API key for Whisper transcription. Get one at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Gemini API key for transcript summarization. Get one at https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# =============================================================================
# Transcription (transcribe_batch.py)
# =============================================================================
# Directory containing audio files to transcribe. Relative to project root.
INPUT_AUDIO_DIR=./input

# Directory where transcript JSON/TXT files are written. Relative to project root.
OUTPUT_DIR=./output

# Whisper model (litellm format: provider/model)
MODEL=groq/whisper-large-v3-turbo

# Optional. Force language (e.g. en, es). Leave empty for auto-detect.
LANGUAGE=

# Optional. Context/hint for the transcription (e.g. topic, names).
TRANS_PROMPT=

# Response format: verbose_json (with timestamps) or json
RESPONSE_FORMAT=verbose_json

# Timestamp granularities for verbose_json: segment, word, or both
TIMESTAMP_GRANULARITIES=segment,word

# Sampling temperature 0-1. Lower = more deterministic.
TEMPERATURE=0

# =============================================================================
# Summarization (summarize.py)
# =============================================================================
# Summarization model (litellm format: provider/model)
GEMINI_MODEL=gemini/gemini-2.5-flash
